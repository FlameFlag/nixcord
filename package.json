{
  "private": true,
  "workspaces": [
    "packages/*",
    "docs/site"
  ],
  "dependencies": {
    "@nixcord/parser": "workspace:*",
    "@nixcord/shared": "workspace:*"
  },
  "scripts": {
    "build": "bun run --filter '*' build && tsgo --build --emitDeclarationOnly --force",
    "test": "vitest run --exclude 'packages/parser/tests/validation/**' --no-isolate --experimental.fsModuleCache --maxWorkers=4",
    "test:all": "bun run test && bun run test:upstream",
    "test:upstream": "vitest run packages/parser/tests/validation/real-world.test.ts --no-isolate --experimental.fsModuleCache --maxWorkers=4",
    "test:watch": "vitest --exclude 'packages/parser/tests/validation/**' --no-isolate --maxWorkers=4",
    "typecheck": "tsgo --build",
    "clean": "rm -rf packages/*/dist",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "fallow dead-code && fallow dupes",
    "lint:health": "fallow health",
    "smoke:built-cli": "bun run build && bun scripts/smoke-built-cli.ts",
    "smoke:upstream": "bun run build && bun scripts/smoke-upstream.ts",
    "drift:plugins": "bun scripts/check-plugin-drift.ts",
    "docs:dev": "bun run --filter nixcord-docs dev",
    "docs:dev:options": "bun run --filter nixcord-docs dev:options",
    "docs:prepare-options": "bun run --filter nixcord-docs prepare-options",
    "docs:build": "bun run --filter nixcord-docs build",
    "docs:check": "bun run --filter nixcord-docs check",
    "docs:preview": "bun run --filter nixcord-docs preview",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run smoke:built-cli"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "@vitest/coverage-v8": "~4.1.7",
    "@vitest/ui": "~4.1.7",
    "equicord": "github:Equicord/Equicord#v1.14.13.3",
    "fallow": "^2.76.0",
    "typescript": "npm:@typescript/typescript6@^6.0.0",
    "vencord": "github:Vendicated/Vencord#v1.14.13",
    "vite": "~8.0.13",
    "vitest": "~4.1.7"
  }
}
